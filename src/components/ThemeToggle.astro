---
/** Flips between dark (brand default) and light, persisting the choice. */
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle color theme"
  class="flex h-8 w-8 items-center justify-center rounded-md border border-line text-muted transition-colors hover:border-magenta hover:text-magenta"
>
  <svg
    class="hidden h-4 w-4 dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
    ></path>
  </svg>
  <svg
    class="h-4 w-4 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
  </svg>
</button>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>

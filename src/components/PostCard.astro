---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../lib/content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
---

<article class="group py-5">
  <a href={`/blog/${post.id}`} class="block">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="text-lg font-medium transition-colors group-hover:text-magenta">
        {post.data.title}
      </h2>
      <time datetime={post.data.date.toISOString()} class="shrink-0 font-mono text-xs text-muted">
        {formatDate(post.data.date)}
      </time>
    </div>
    <p class="mt-1 text-sm text-muted">{post.data.description}</p>
  </a>
</article>

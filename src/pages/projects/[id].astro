---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { coverOgImage, formatDate } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const ogImage = coverOgImage(project.data.cover, Astro.site);
---

<Layout
  title={project.data.title}
  description={project.data.description}
  ogImage={ogImage}
  ogType="article"
>
  <article>
    <header>
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-3xl font-semibold tracking-tight">{project.data.title}</h1>
        <StatusBadge status={project.data.status} />
      </div>
      <p class="mt-3 text-muted">{project.data.description}</p>

      <div class="mt-5 flex flex-wrap gap-4 font-mono text-sm">
        <a
          href={project.data.repoUrl}
          class="rounded-md border border-line px-3 py-1.5 text-cyan transition-all hover:border-cyan hover:shadow-[0_0_16px_var(--c-glow)]"
        >
          View code →
        </a>
        {
          project.data.demoUrl && (
            <a
              href={project.data.demoUrl}
              class="rounded-md border border-line px-3 py-1.5 text-magenta transition-all hover:border-magenta hover:shadow-[0_0_16px_var(--c-glow)]"
            >
              Live demo →
            </a>
          )
        }
      </div>

      {
        project.data.tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2 font-mono text-xs text-muted">
            {project.data.tags.map((tag) => (
              <span>{tag}</span>
            ))}
            <span>· {formatDate(project.data.date)}</span>
          </div>
        )
      }

      {
        project.data.cover && (
          <Image
            src={project.data.cover}
            alt=""
            class="mt-6 w-full rounded-lg border border-line"
          />
        )
      }
    </header>
    <div class="prose mt-8 max-w-none">
      <Content />
    </div>
  </article>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404" description="Page not found.">
  <section class="py-20 text-center">
    <p class="font-mono text-6xl font-bold">
      <span class="text-magenta">4</span><span class="text-cyan">0</span><span
        class="text-magenta">4</span
      >
    </p>
    <p class="mt-4 text-muted">This page doesn't exist — or it hasn't shipped yet.</p>
    <a href="/" class="mt-6 inline-block font-mono text-sm text-cyan hover:text-magenta"
      >← back home</a
    >
  </section>
</Layout>

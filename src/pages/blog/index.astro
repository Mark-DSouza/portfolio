---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getPublishedTags } from '../../lib/content';
import TagPill from '../../components/TagPill.astro';

const posts = await getPublishedPosts();
const tags = await getPublishedTags();
---

<Layout title="Blog" description="Writing on software engineering by Mark D'Souza.">
  <h1 class="font-mono text-sm tracking-widest text-cyan uppercase">Blog</h1>

  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <TagPill tag={tag} />
        ))}
      </div>
    )
  }

  {
    posts.length > 0 ? (
      <div class="mt-4 divide-y divide-line">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="mt-8 text-muted">First post coming soon.</p>
    )
  }
</Layout>
